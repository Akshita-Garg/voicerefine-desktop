{
  "name": "voicerefine-desktop",
  "productName": "VoiceRefine",
  "version": "1.0.0",
  "description": "Local-first desktop dictation with transcription, cleanup, and transform workflows.",
  "main": ".vite/build/main.js",
  "private": true,
  "scripts": {
    "start": "electron-forge start",
    "package": "electron-forge package",
    "make": "electron-forge make",
    "make:win:installer": "npm run package && electron-builder --win nsis-web --x64 --prepackaged out/VoiceRefine-win32-x64 --publish never",
    "publish": "electron-forge publish",
    "lint": "echo \"No linting configured\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "benchmark:refinement": "node scripts/benchmark-refinement.mjs",
    "eval:transform": "node scripts/evaluate-transform-prompts.mjs"
  },
  "keywords": [],
  "author": {
    "name": "Akshita Garg",
    "email": "akshitagarg0208@gmail.com"
  },
  "license": "MIT",
    "build": {
    "appId": "com.voicerefine.desktop",
    "productName": "VoiceRefine",
    "icon": "resources/icons/icon.ico",
    "directories": {
      "output": "dist"
    },
    "publish": {
      "provider": "github",
      "owner": "Akshita-Garg",
      "repo": "voicerefine-desktop"
    },
    "nsis": {
      "artifactName": "VoiceRefineSetup-${version}.${ext}",
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "VoiceRefine",
      "deleteAppDataOnUninstall": false
    }
  },
  "devDependencies": {
    "@electron-forge/cli": "^7.11.2",
    "@electron-forge/maker-deb": "^7.11.2",
    "@electron-forge/maker-rpm": "^7.11.2",
    "@electron-forge/maker-squirrel": "^7.11.2",
    "@electron-forge/maker-zip": "^7.11.2",
    "@electron-forge/plugin-auto-unpack-natives": "^7.11.2",
    "@electron-forge/plugin-fuses": "^7.11.2",
    "@electron-forge/plugin-vite": "^7.11.2",
    "@electron/fuses": "^1.8.0",
    "@electron/rebuild": "^4.0.4",
    "@tailwindcss/vite": "^4.3.0",
    "@vitejs/plugin-react": "^4.7.0",
    "electron": "42.2.0",
    "electron-builder": "^26.15.2",
    "electron-rebuild": "^3.2.9",
    "tailwindcss": "^4.3.0",
    "vite": "^5.4.21",
    "vitest": "^4.1.7"
  },
  "dependencies": {
    "electron-squirrel-startup": "^1.0.1",
    "lucide-react": "^1.16.0",
    "node-llama-cpp": "^3.18.1",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "sherpa-onnx-node": "^1.13.2"
  }
}
